---
/**
 * /stack — Full Infrastructure Stack + Competency Radar (spec §4.4).
 *
 * Two-section composition:
 *   1. RadarChart island (inline SVG, zero deps) — quick visual signal.
 *   2. Categorised badge grid mirroring the README badge surface.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import GradientDivider from '@components/GradientDivider.astro';
import TechBadge from '@components/TechBadge.astro';
import RadarChart from '@islands/RadarChart.svelte';
import { accentVar } from '@lib/accents';

import { competencyAxes } from '@data/competency';
import { stackCategories } from '@data/stack';
---

<BaseLayout
  title="Stack — Surya Avala"
  description="Full infrastructure stack and self-assessed competency radar across MLOps, GenAI, distributed systems, and cloud."
>
  <main id="main" class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12 lg:py-16">
    <header class="mb-8">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-text-muted">~/stack</p>
      <h1
        class="mt-2 font-mono text-3xl font-semibold tracking-tight text-text-primary sm:text-4xl"
      >
        Infrastructure stack & competency radar
      </h1>
      <p class="mt-3 max-w-2xl text-sm text-text-muted sm:text-base">
        Self-assessed across 10+ years of production execution. Hover any radar vertex for the
        evidence basis.
      </p>
      <GradientDivider spacing="mt-6 mb-0" />
    </header>

    <section class="mb-16" aria-labelledby="radar-section">
      <header class="mb-6 flex items-baseline justify-between">
        <h2 id="radar-section" class="font-mono text-lg text-text-primary sm:text-xl">
          Competency Radar
        </h2>
        <span class="font-mono text-xs text-text-muted">8 axes · 0–100</span>
      </header>
      <div class="grid items-start gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
        <div class="rounded-lg border border-border-base/60 bg-bg-surface/60 p-6">
          <RadarChart client:visible axes={competencyAxes} />
        </div>
        <ul class="space-y-2 font-mono text-sm" role="list">
          {
            competencyAxes.map((axis) => (
              <li class="flex items-start justify-between gap-4 rounded-md border border-border-base/40 bg-bg-surface/40 p-3">
                <div class="flex-1">
                  <p class="text-text-primary">
                    <span class="text-brand">{axis.label}</span>
                    <span class="text-text-muted"> · {axis.score}/100</span>
                  </p>
                  <p class="mt-1 text-xs leading-snug text-text-muted">{axis.methodology}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
      <p class="mt-6 max-w-3xl text-xs leading-relaxed text-text-muted">
        <em>Self-Assessment Methodology Note:</em> Competency scores are self-assessed based on production
        execution breadth, not academic certification. Each axis includes a methodology string providing
        the evidence basis. Hover any radar vertex to see it.
      </p>
    </section>

    <section aria-labelledby="stack-section">
      <header class="mb-6 flex items-baseline justify-between">
        <h2 id="stack-section" class="font-mono text-lg text-text-primary sm:text-xl">
          Full Infrastructure Stack
        </h2>
        <span class="font-mono text-xs text-text-muted">
          {stackCategories.length} categories
        </span>
      </header>

      <div class="grid gap-4 sm:grid-cols-2">
        {
          stackCategories.map((cat) => (
            <article
              class="rounded-lg border border-border-base/60 bg-bg-surface/60 p-5 transition-all duration-200 hover:border-stack hover:shadow-glow-impact"
              style={`--cat-accent: var(--accent-${cat.accent})`}
            >
              <header class="mb-3 flex items-center gap-2">
                <span
                  aria-hidden="true"
                  class="inline-block h-2 w-2 rounded-full"
                  style={`background-color: ${accentVar(cat.accent)}`}
                />
                <h3
                  class="font-mono text-sm uppercase tracking-widest"
                  style={`color: ${accentVar(cat.accent)}`}
                >
                  {cat.name}
                </h3>
              </header>
              <ul class="flex flex-wrap gap-1.5" role="list">
                {cat.items.map((item) => (
                  <li>
                    <TechBadge accent={cat.accent}>{item}</TechBadge>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
