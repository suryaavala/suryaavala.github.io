---
/**
 * /architecture — Portfolio (spec §4.2).
 *
 * Categorised strictly by domain, NOT chronologically. The Bento card
 * rendering preserves the homepage visual grammar; the Upstream Contributions
 * section anchors at #oss for the cross-link from the homepage OSS card.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import BentoCard from '@components/BentoCard.astro';
import TechBadge from '@components/TechBadge.astro';
import GradientDivider from '@components/GradientDivider.astro';
import { accentVar } from '@lib/accents';

import { projects, upstreamPRs } from '@data/projects';
import { ProjectDomain } from '@data/schemas';

// Group projects by domain in the spec-mandated order.
const domainOrder = ProjectDomain.options;
const grouped = domainOrder.map((domain) => ({
  domain,
  items: projects.filter((p) => p.domain === domain)
}));

const accentForDomain: Record<string, 'brand' | 'infra' | 'impact' | 'human' | 'status' | 'stack'> =
  {
    'GenAI & Agentic Systems': 'infra',
    'Systems & Infrastructure': 'brand',
    'ML & Data Science': 'stack',
    'Data Engineering & Tooling': 'status',
    'Enterprise ML & Document Intelligence': 'impact'
  };
---

<BaseLayout
  title="Architecture — Surya Avala"
  description="Portfolio of production AI systems, infrastructure, and OSS contributions, categorised by domain."
>
  <main id="main" class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12 lg:py-16">
    <header class="mb-8">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-text-muted">~/architecture</p>
      <h1
        class="mt-2 font-mono text-3xl font-semibold tracking-tight text-text-primary sm:text-4xl"
      >
        Portfolio · categorised by domain
      </h1>
      <p class="mt-3 max-w-2xl text-sm text-text-muted sm:text-base">
        Production systems, OSS contributions, and exploratory work — grouped by what they prove,
        not when they were built.
      </p>
      <GradientDivider spacing="mt-6 mb-0" />
    </header>

    {
      grouped.map(({ domain, items }) => (
        <section class="mb-12" aria-labelledby={`domain-${domain.replace(/\s+/g, '-')}`}>
          <header class="mb-4 flex items-center justify-between">
            <h2
              id={`domain-${domain.replace(/\s+/g, '-')}`}
              class="font-mono text-lg text-text-primary sm:text-xl"
            >
              {domain}
            </h2>
            <span class="font-mono text-xs text-text-muted">
              {items.length} project{items.length === 1 ? '' : 's'}
            </span>
          </header>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {items.map((project) => (
              <BentoCard
                accent={accentForDomain[domain] ?? 'brand'}
                href={project.repoUrl}
                rel="noopener external"
                badge={project.badgeLabel}
                ariaLabelledby={`project-${project.slug}`}
              >
                <h3
                  id={`project-${project.slug}`}
                  class="font-mono text-base text-text-primary"
                  style={`color: ${accentVar(project.accentColor)}`}
                >
                  {project.title}
                </h3>
                <p class="text-sm leading-snug text-text-primary">{project.description}</p>
                <ul class="mt-auto flex flex-wrap gap-1.5 pt-2" role="list">
                  {project.tags.slice(0, 6).map((tag) => (
                    <li>
                      <TechBadge accent={project.accentColor}>{tag}</TechBadge>
                    </li>
                  ))}
                </ul>
              </BentoCard>
            ))}
          </div>
        </section>
      ))
    }

    {/* Upstream OSS — anchored at #oss for the homepage cross-link */}
    <section id="oss" class="scroll-mt-24" aria-labelledby="oss-title">
      <header class="mb-4 flex items-center gap-2">
        <span aria-hidden="true" class="text-status">↟</span>
        <h2 id="oss-title" class="font-mono text-lg text-status sm:text-xl">
          Upstream Contributions
        </h2>
      </header>
      <p class="mb-4 max-w-2xl text-sm text-text-muted">
        Patches merged into MLOps and data-infrastructure projects.
      </p>
      <div class="grid gap-3">
        {
          upstreamPRs.map((pr) => (
            <a
              href={pr.url}
              rel="noopener external"
              class="group flex items-baseline justify-between gap-4 rounded-md border border-border-base/60 bg-bg-surface/60 px-4 py-3 transition-all hover:border-status hover:shadow-glow-status"
            >
              <span class="font-mono text-sm text-text-primary">
                <span class="text-status">{pr.repo}</span>
                <span class="text-text-muted"> #{pr.prNumber}</span>
                <span class="block text-xs text-text-muted group-hover:text-text-primary sm:inline sm:pl-2">
                  {pr.title}
                </span>
              </span>
              <span aria-hidden="true" class="font-mono text-xs text-text-muted">
                ↗
              </span>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
