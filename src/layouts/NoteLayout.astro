---
/**
 * NoteLayout — wraps individual MDX notes (spec §4.5).
 *
 * The `requiresMath` frontmatter flag drives BaseLayout's conditional KaTeX
 * CSS injection (plan §key decision #5) — non-math notes pay zero KaTeX cost.
 *
 * Prose styling comes from the @tailwindcss/typography plugin with our
 * Dracula token overrides; Shiki has already inlined per-token styling at
 * build time, so prose code blocks render with theme tokens without runtime
 * JS or external CSS.
 */

import BaseLayout from './BaseLayout.astro';

import type { CollectionEntry } from 'astro:content';

export interface Props {
  /** Collection entry as passed by /notes/[...slug].astro. */
  entry: CollectionEntry<'notes'>;
}

const { entry } = Astro.props;
const { data } = entry;

const publishDateISO = data.publishDate.toISOString().slice(0, 10);
const publishDateLabel = data.publishDate.toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout
  title={`${data.title} — Surya Avala`}
  description={data.description}
  requiresMath={data.requiresMath}
>
  <article id="main" class="mx-auto max-w-3xl px-4 py-8 sm:px-6 sm:py-12 lg:py-16">
    <header class="mb-8">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-text-muted">
        ~/notes/{entry.slug}
      </p>
      <h1
        class="mt-2 font-mono text-3xl font-semibold leading-tight tracking-tight text-text-primary sm:text-4xl"
      >
        {data.title}
      </h1>
      <p class="mt-3 text-base text-text-muted sm:text-lg">{data.description}</p>
      <div class="mt-4 flex flex-wrap items-center gap-3 font-mono text-xs text-text-muted">
        <time datetime={publishDateISO}>{publishDateLabel}</time>
        <span aria-hidden="true">·</span>
        <span class="rounded-full border border-border-base/60 px-2 py-0.5 text-brand">
          {data.category}
        </span>
        {
          data.tags.map((tag) => (
            <span class="rounded-full border border-border-base/40 px-2 py-0.5">{tag}</span>
          ))
        }
      </div>
      {
        data.commercialContext && (
          <p class="mt-3 rounded-md border border-impact/40 bg-impact/5 px-3 py-2 font-mono text-xs text-impact">
            ▸ {data.commercialContext}
          </p>
        )
      }
    </header>

    <div
      class="prose prose-invert max-w-none prose-headings:font-mono prose-headings:tracking-tight prose-a:text-brand-body prose-a:underline-offset-4 prose-pre:rounded-lg prose-pre:border prose-pre:border-border-base/60"
    >
      <slot />
    </div>

    {
      /* Shiki github-dark-dimmed comment colour #768390 has only 3.87:1 on its
        background #22272e — fails WCAG 1.4.3 AA at 14px. Brighten to #8b949e
        (4.98:1, the non-dimmed github-dark comment colour). */
    }
    <style is:global>
      .astro-code span[style*='#768390'] {
        color: #8b949e !important;
      }
    </style>

    <footer class="mt-12 border-t border-border-base/60 pt-6 text-sm text-text-muted">
      <p>
        Found a bug or have feedback?
        <a
          class="text-brand underline decoration-brand/50 underline-offset-4 hover:decoration-brand"
          href="/ping">Open a TCP socket →</a
        >
      </p>
    </footer>
  </article>
</BaseLayout>
