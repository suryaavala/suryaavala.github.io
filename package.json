{
  "name": "suryaavala-com",
  "description": "suryaavala.com v2 — Personal Architecture Platform. Astro v4 + Svelte islands + MDX.",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.12.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "prebuild": "tsx scripts/validate-data.ts && tsx scripts/check-staleness.ts",
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro build",
    "preview": "astro preview --host 0.0.0.0 --port 4321",
    "astro": "astro",
    "check": "astro check",
    "lint": "prettier --check . && eslint src tests scripts --ext .ts,.tsx,.astro,.svelte,.mjs",
    "format": "prettier --write .",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:unit:ui": "vitest --ui --api.host 0.0.0.0 --api.port 51204",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps",
    "lhci": "lhci autorun --config=./lighthouserc.json",
    "size": "size-limit",
    "verify": "npm run lint && npm run check && npm run test:unit:run && npm run build",
    "check-dep-pinning": "node scripts/check-dep-pinning.mjs",
    "check-staleness": "tsx scripts/check-staleness.ts",
    "validate-data": "tsx scripts/validate-data.ts",
    "generate-og": "tsx scripts/generate-og.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "3.1.9",
    "@astrojs/rss": "4.0.10",
    "@astrojs/sitemap": "3.2.1",
    "@astrojs/svelte": "5.7.2",
    "@astrojs/tailwind": "5.1.3",
    "astro": "4.16.18",
    "katex": "0.16.45",
    "rehype-katex": "7.0.1",
    "remark-math": "6.0.0",
    "svelte": "4.2.19",
    "tailwindcss": "3.4.17",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.4",
    "@axe-core/playwright": "4.10.1",
    "@lhci/cli": "0.14.0",
    "@playwright/test": "1.49.1",
    "@size-limit/preset-app": "11.1.6",
    "@tailwindcss/typography": "0.5.15",
    "@types/node": "20.17.10",
    "@types/semver": "7.5.8",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "@vitest/ui": "2.1.8",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-plugin-astro": "1.3.1",
    "eslint-plugin-svelte": "2.46.1",
    "happy-dom": "15.11.7",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-svelte": "3.3.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "semver": "7.6.3",
    "size-limit": "11.1.6",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  },
  "size-limit": [
    {
      "name": "All Astro JS (gzipped)",
      "path": "dist/_astro/*.js",
      "limit": "15 KB"
    },
    {
      "name": "Theme toggle island (must stay tiny — FOUC gate uses client:load)",
      "path": "dist/_astro/ThemeToggle*.js",
      "limit": "2 KB"
    }
  ]
}
